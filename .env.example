# Copy to ".env" and fill in real values. Never commit ".env".

# true = no Gemini/Firestore; in-memory DB + mock ratings for local UI testing
LOCAL_DEV=true

# Google AI (required when LOCAL_DEV=false)
GEMINI_API_KEY=

# Optional; default is gemini-1.5-flash
# GEMINI_MODEL=gemini-1.5-flash

# Firestore (required when LOCAL_DEV=false)
FIRESTORE_PROJECT_ID=
# Path to service account JSON on your machine (or omit if using ADC)
FIRESTORE_KEY_FILE=

# Quotes/comments with rating below this are not published (default 3)
RATING_THRESHOLD=3
